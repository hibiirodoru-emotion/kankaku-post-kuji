<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <title>感覚 × 投稿くじ</title>
  <style>
    :root {
      color-scheme: light;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      background: #FAF8FF;
      color: #1a1a1a;
      min-height: 100%;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
    }

    body {
      min-height: 100vh;
    }

    .app {
      max-width: 420px;
      margin: 0 auto;
      padding: 1.5rem 1rem 2rem;
    }

    .header {
      text-align: center;
      margin-bottom: 2rem;
      padding-top: 0.5rem;
    }

    .header h1 {
      font-size: 20px;
      font-weight: 600;
      color: #1a1a1a;
      letter-spacing: 0.02em;
    }

    .header p {
      font-size: 13px;
      color: #6f6a7a;
      margin-top: 6px;
      line-height: 1.6;
    }

    .mood-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 1.5rem;
    }

    .mood-btn {
      appearance: none;
      -webkit-appearance: none;
      background: #ffffff;
      border: 1px solid #e6deef;
      border-radius: 16px;
      padding: 14px 12px;
      cursor: pointer;
      transition: all 0.18s ease;
      text-align: center;
      color: #1a1a1a;
    }

    .mood-btn:hover {
      border-color: #cdb6e8;
      background: #fbf8ff;
      transform: translateY(-1px);
    }

    .mood-btn.selected {
      border: 1.5px solid #c4a8e0;
      background: #f8f2ff;
      box-shadow: 0 0 0 3px rgba(196, 168, 224, 0.12);
    }

    .mood-btn .icon {
      font-size: 22px;
      display: block;
      margin-bottom: 6px;
      line-height: 1;
    }

    .mood-btn .label {
      font-size: 13px;
      color: #1a1a1a;
      font-weight: 500;
    }

    .draw-btn {
      width: 100%;
      padding: 15px;
      border-radius: 999px;
      border: none;
      background: linear-gradient(135deg, #d4b8f0 0%, #b8d4f0 100%);
      color: #3c2878;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.18s;
      letter-spacing: 0.02em;
    }

    .draw-btn:hover {
      transform: translateY(-1px);
      opacity: 0.95;
    }

    .draw-btn:active {
      transform: scale(0.98);
    }

    .draw-btn:disabled {
      opacity: 0.5;
      cursor: default;
      transform: none;
    }

    .result-card {
      background: #ffffff;
      border: 1px solid #e6deef;
      border-radius: 20px;
      padding: 1.5rem;
      margin-top: 1.25rem;
      display: none;
      box-shadow: 0 10px 30px rgba(116, 95, 150, 0.08);
    }

    .result-card.show {
      display: block;
      animation: fadeUp 0.4s ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .result-mood-tag {
      display: inline-block;
      background: #f3ecf9;
      color: #7c4eae;
      font-size: 11px;
      padding: 4px 12px;
      border-radius: 999px;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .result-section {
      margin-bottom: 1.1rem;
    }

    .result-section:last-child {
      margin-bottom: 0;
    }

    .result-label {
      font-size: 11px;
      color: #8b8398;
      letter-spacing: 0.08em;
      margin-bottom: 5px;
    }

    .result-theme {
      font-size: 20px;
      font-weight: 600;
      color: #1a1a1a;
      line-height: 1.45;
    }

    .result-angle {
      font-size: 14px;
      color: #1a1a1a;
      background: #f7f5fb;
      padding: 10px 14px;
      border-radius: 10px;
      line-height: 1.6;
    }

    .steps-list {
      list-style: none;
    }

    .steps-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 7px;
      font-size: 13px;
      color: #1a1a1a;
      line-height: 1.6;
    }

    .step-num {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #ede6f7;
      color: #7c4eae;
      font-size: 11px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .message-box {
      background: linear-gradient(135deg, #f8f2ff 0%, #eff6ff 100%);
      border-radius: 14px;
      padding: 14px 16px;
      text-align: center;
      font-size: 14px;
      color: #5b4a8a;
      font-weight: 500;
      line-height: 1.6;
    }

    .divider {
      height: 1px;
      background: #ece5f3;
      margin: 1rem 0;
    }

    .again-btn {
      width: 100%;
      margin-top: 1rem;
      padding: 12px;
      border-radius: 999px;
      border: 1px solid #d6cae5;
      background: transparent;
      color: #7a7287;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .again-btn:hover {
      background: #f7f5fb;
      color: #1a1a1a;
    }

    .footer {
      text-align: center;
      margin-top: 2rem;
      font-size: 11px;
      color: #aaa;
      letter-spacing: 0.06em;
      line-height: 1.9;
    }

    .footer a {
      color: #7C4EAE;
      text-decoration: none;
      font-size: 12px;
      font-weight: 500;
    }

    .footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="header">
      <h1>感覚 × 投稿くじ ✦</h1>
      <p>今の気分を選んで、投稿アイデアを引こう</p>
    </div>

    <div class="mood-grid" id="moodGrid">
      <button class="mood-btn" data-mood="もやもや" onclick="selectMood(this)">
        <span class="icon">💭</span>
        <span class="label">なんとなくモヤモヤ</span>
      </button>
      <button class="mood-btn" data-mood="前向き" onclick="selectMood(this)">
        <span class="icon">🌱</span>
        <span class="label">ちょっと前向き</span>
      </button>
      <button class="mood-btn" data-mood="落ち着きたい" onclick="selectMood(this)">
        <span class="icon">🍵</span>
        <span class="label">落ち着きたい</span>
      </button>
      <button class="mood-btn" data-mood="伝えたい" onclick="selectMood(this)">
        <span class="icon">💌</span>
        <span class="label">誰かに伝えたい</span>
      </button>
      <button class="mood-btn" data-mood="整えたい" onclick="selectMood(this)" style="grid-column: span 2;">
        <span class="icon">🪴</span>
        <span class="label">整えたい</span>
      </button>
    </div>

    <button class="draw-btn" id="drawBtn" onclick="draw()" disabled>✦ 投稿テーマを引く</button>

    <div class="result-card" id="resultCard">
      <span class="result-mood-tag" id="moodTag"></span>
      <div class="result-section">
        <div class="result-label">投稿テーマ</div>
        <div class="result-theme" id="rTheme"></div>
      </div>
      <div class="divider"></div>
      <div class="result-section">
        <div class="result-label">切り口</div>
        <div class="result-angle" id="rAngle"></div>
      </div>
      <div class="result-section">
        <div class="result-label">投稿の構成</div>
        <ul class="steps-list" id="rSteps"></ul>
      </div>
      <div class="divider"></div>
      <div class="message-box" id="rMessage"></div>
      <button class="again-btn" onclick="drawAgain()">↺ もう一回引く</button>
    </div>

    <div class="footer">
      <div>hiirodoru / AI × Design</div>
      <a href="https://www.instagram.com/eririn_design/" target="_blank" rel="noopener noreferrer">
        @eririn_design
      </a>
    </div>
  </div>

  <script>
    const DATA = {
      "もやもや": [
        { theme: "最近やめたこと", angle: "Before→After形式で書く", steps: ["以前の自分のクセや習慣を話す", "やめようと思ったきっかけ", "今どう変わったかを正直に書く"], message: "モヤモヤの奥に、本当に大切なものがある" },
        { theme: "うまくいかなかった話", angle: "失敗から始める", steps: ["やらかしたエピソードを正直に", "そこから気づいたこと", "今の自分へのメッセージ"], message: "うまくいかない日があるから、気づけることがある" },
        { theme: "比べてしまった自分の話", angle: "本音の告白から始める", steps: ["比べてしまった瞬間", "そのとき感じた気持ち", "今、自分に言いたいこと"], message: "今のあなたの感覚で、大丈夫" }
      ],
      "前向き": [
        { theme: "最近気づいたこと・小さな変化", angle: "質問から始める", steps: ["何気ない出来事を書く", "そこからの気づき", "読む人へのエール"], message: "ちゃんと向き合ってるね、えらい" },
        { theme: "続けてみてわかったこと", angle: "Before→After形式", steps: ["始めたときの気持ち", "途中でしんどかったこと", "続けて見えてきたこと"], message: "小さく続けた日々が、あなたを作ってる" },
        { theme: "自分のターニングポイント", angle: "エピソードから始める", steps: ["あの日の話", "そのとき感じたこと", "今どう活きているか"], message: "あのときの選択が、今日に繋がってる" }
      ],
      "落ち着きたい": [
        { theme: "大切にしている時間・習慣", angle: "情景描写から始める", steps: ["どんな時間か具体的に描写", "なぜ大切なのか", "読む人への問いかけ"], message: "そのままで伝えていい" },
        { theme: "自分のペースを取り戻した話", angle: "正直な出発点から", steps: ["無理していた頃の話", "立ち止まったきっかけ", "今心がけていること"], message: "あなたのペースが、あなたのリズム" },
        { theme: "好きなもの・心地よいもの", angle: "安心感から始める", steps: ["お気に入りのものや場所", "それが好きな理由", "同じ感覚の人への共感"], message: "好きって言える感覚を大事に" }
      ],
      "伝えたい": [
        { theme: "過去の自分に伝えたいこと", angle: "手紙形式で書く", steps: ["昔の自分への語りかけ", "あのころ知っておきたかったこと", "今の自分からのメッセージ"], message: "あなたの言葉が、誰かの明日を変えるかもしれない" },
        { theme: "誰かに支えてもらった話", angle: "感謝エピソードから始める", steps: ["しんどかったときの状況", "救われた言葉や行動", "誰かに返していきたいこと"], message: "もらった温かさを、ことばにしてみよう" },
        { theme: "自分が信じていること", angle: "宣言から始める", steps: ["信じていることを一言で", "そう思うようになった理由", "同じ想いの人へのメッセージ"], message: "あなたの言葉を待ってる人がいる" }
      ],
      "整えたい": [
        { theme: "見直してよかったこと", angle: "しんどさから始める", steps: ["放置していたこと", "見直したきっかけ", "変えて気づいたこと"], message: "整えることは、自分を大切にすること" },
        { theme: "自分のルーティン・こだわり", angle: "続けている誇りから", steps: ["続けていること", "なぜ続けられるのか", "真似しやすいポイント"], message: "毎日のちいさな積み重ねが、あなたをつくる" },
        { theme: "手放してよかったもの", angle: "気づきの告白形式", steps: ["手放す前の状態", "手放したきっかけ", "空いた余白に入ってきたもの"], message: "余白が、新しい自分を招く" }
      ]
    };

    let selectedMood = null;
    let currentData = null;

    function selectMood(btn) {
      document.querySelectorAll(".mood-btn").forEach(b => b.classList.remove("selected"));
      btn.classList.add("selected");
      selectedMood = btn.dataset.mood;
      document.getElementById("drawBtn").disabled = false;
      document.getElementById("resultCard").classList.remove("show");
    }

    function getRandom(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function draw() {
      if (!selectedMood) return;
      const pool = DATA[selectedMood];
      let pick = getRandom(pool);
      if (currentData === pick && pool.length > 1) {
        pick = getRandom(pool.filter(d => d !== currentData));
      }
      currentData = pick;
      showResult(pick);
    }

    function drawAgain() {
      draw();
    }

    function showResult(d) {
      document.getElementById("moodTag").textContent = "# " + selectedMood;
      document.getElementById("rTheme").textContent = d.theme;
      document.getElementById("rAngle").textContent = d.angle;

      const ul = document.getElementById("rSteps");
      ul.innerHTML = "";

      d.steps.forEach((s, i) => {
        const li = document.createElement("li");
        li.innerHTML = `<span class="step-num">${i + 1}</span><span>${s}</span>`;
        ul.appendChild(li);
      });

      document.getElementById("rMessage").textContent = "✦ " + d.message;

      const card = document.getElementById("resultCard");
      card.classList.remove("show");
      void card.offsetWidth;
      card.classList.add("show");
    }
  </script>
</body>
</html>
